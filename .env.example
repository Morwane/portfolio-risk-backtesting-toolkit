# LSEG credentials — copy to .env and fill in your values
# .env is gitignored; never commit real credentials

# For Eikon / LSEG Workspace (desktop platform session)
LSEG_APP_KEY=your_app_key_here

# For deployed / server sessions (LSEG Data Library)
LSEG_CLIENT_ID=your_client_id_here
LSEG_CLIENT_SECRET=your_client_secret_here
